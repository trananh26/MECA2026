<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Sidebar -->
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#1A2332"/>
    <SolidColorBrush x:Key="SidebarForegroundBrush" Color="#E8EDF2"/>
    <SolidColorBrush x:Key="SidebarMutedBrush" Color="#8B9CB3"/>
    <SolidColorBrush x:Key="SidebarBorderBrush" Color="#2D3A4F"/>

    <!-- Nền chính -->
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#EDF1F5"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="#D0DAE5"/>
    <SolidColorBrush x:Key="BorderMediumBrush" Color="#B0BEC9"/>
    <SolidColorBrush x:Key="StatBoxBackgroundBrush" Color="#E8EEF3"/>

    <!-- Nút -->
    <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="#2C3E50"/>
    <SolidColorBrush x:Key="ButtonPrimaryBorderBrush" Color="#3D5166"/>

    <!-- Buffer / kho -->
    <SolidColorBrush x:Key="BufferEmptyBrush" Color="#C5D5E4"/>
    <SolidColorBrush x:Key="BufferEmptyTextBrush" Color="#2C3E50"/>
    <SolidColorBrush x:Key="BufferFullBrush" Color="#1E7A5C"/>
    <SolidColorBrush x:Key="BufferFullTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BufferDetailTextBrush" Color="#D5E3EF"/>

    <!-- Gauge -->
    <SolidColorBrush x:Key="GaugeArcPrimaryBrush" Color="#5DADE2"/>
    <SolidColorBrush x:Key="GaugeArcSecondaryBrush" Color="#D4A574"/>
    <SolidColorBrush x:Key="GaugeCenterBrush" Color="#2C3E50"/>
    <SolidColorBrush x:Key="GaugeLabelBrush" Color="#2C3E50"/>
    <SolidColorBrush x:Key="GaugeLegendBrush" Color="#5DADE2"/>

    <!-- Map -->
    <SolidColorBrush x:Key="MapLinkBrush" Color="#A8B4C0"/>
    <SolidColorBrush x:Key="MapNodeBrush" Color="#7F8C9A"/>

</ResourceDictionary>
