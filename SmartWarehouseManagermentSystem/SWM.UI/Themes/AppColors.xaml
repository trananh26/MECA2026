<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Sidebar -->
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#1A2332"/>
    <SolidColorBrush x:Key="SidebarForegroundBrush" Color="#E8EDF2"/>
    <SolidColorBrush x:Key="SidebarMutedBrush" Color="#8B9CB3"/>
    <SolidColorBrush x:Key="SidebarBorderBrush" Color="#2D3A4F"/>

    <!-- Nền chính -->
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#EEF3F0"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FAFCFB"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="#C5D9CE"/>
    <SolidColorBrush x:Key="BorderMediumBrush" Color="#9DB5A8"/>
    <SolidColorBrush x:Key="StatBoxBackgroundBrush" Color="#F4F8F6"/>

    <!-- Nút -->
    <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="#2C3E50"/>
    <SolidColorBrush x:Key="ButtonPrimaryBorderBrush" Color="#3D5166"/>

    <!-- Buffer / kho -->
    <SolidColorBrush x:Key="BufferEmptyBrush" Color="#D4EDDA"/>
    <SolidColorBrush x:Key="BufferEmptyTextBrush" Color="#2E5E45"/>
    <SolidColorBrush x:Key="BufferEmptyBorderBrush" Color="#A8C9B4"/>
    <SolidColorBrush x:Key="BufferFullBrush" Color="#2E7D5A"/>
    <SolidColorBrush x:Key="BufferFullTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BufferDetailTextBrush" Color="#E2F2E9"/>

    <!-- Gauge -->
    <SolidColorBrush x:Key="GaugeArcPrimaryBrush" Color="#5DADE2"/>
    <SolidColorBrush x:Key="GaugeArcSecondaryBrush" Color="#D4A574"/>
    <SolidColorBrush x:Key="GaugeCenterBrush" Color="#2C3E50"/>
    <SolidColorBrush x:Key="GaugeLabelBrush" Color="#2C3E50"/>
    <SolidColorBrush x:Key="GaugeLegendBrush" Color="#5DADE2"/>

    <!-- Map -->
    <SolidColorBrush x:Key="MapLinkBrush" Color="#8FAF9E"/>
    <SolidColorBrush x:Key="MapNodeBrush" Color="#6B8F7E"/>

    <!-- Trạng thái kết nối -->
    <SolidColorBrush x:Key="StatusOnlineBrush" Color="#27AE60"/>
    <SolidColorBrush x:Key="StatusOfflineBrush" Color="#E74C3C"/>
    <SolidColorBrush x:Key="StatusWarningBrush" Color="#E67E22"/>
    <SolidColorBrush x:Key="PanelHeaderBrush" Color="#2C3E50"/>
    <SolidColorBrush x:Key="PanelMutedTextBrush" Color="#6B7C93"/>

</ResourceDictionary>
