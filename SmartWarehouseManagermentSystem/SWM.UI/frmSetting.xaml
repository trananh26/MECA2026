<Window x:Class="SWM.UI.frmSetting"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SWM.UI"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d" WindowStartupLocation="CenterScreen"
        Title="Cài đặt chung" Height="780" Width="1300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.1*"/>
            <RowDefinition Height="19*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="AliceBlue"></Grid>
        <Grid Grid.Row="1" Background="AliceBlue">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <materialDesign:Card Margin="16">
                    <GroupBox Background="AliceBlue" materialDesign:ColorZoneAssist.Mode="Standard"
                                      Header="Thêm người sử dụng" Style="{DynamicResource MaterialDesignGroupBox}" 
                                      FontSize="12" materialDesign:ShadowAssist.ShadowDepth="Depth3" BorderThickness="0">

                        <StackPanel>
                            <TextBlock Width="200" Height="30" VerticalAlignment="Bottom" Margin="0,10,10,-50" 
                                                   Text="Tên hiển thị (*)" HorizontalAlignment="Left" FontWeight="Bold"/>

                            <TextBox x:Name="txtDisplayName" Style="{StaticResource MaterialDesignOutlinedTextFieldTextBox}"
                                                  VerticalAlignment="Top" Margin="0,10,10,0" Height="40" Width="440"
                                                  AcceptsReturn="True" TextWrapping="Wrap" HorizontalAlignment="Right"
                                                 VerticalScrollBarVisibility="Auto" materialDesign:HintAssist.Hint="Tên hiển thị"
                                                 IsEnabled="{Binding Path=IsChecked, ElementName=MaterialDesignOutlinedTextFieldTextBoxEnabledComboBox}" />

                            <TextBlock Width="200" Height="30" VerticalAlignment="Bottom" Margin="0,10,10,-50" 
                                                   Text="Mã nhân viên (*)" HorizontalAlignment="Left" FontWeight="Bold"/>

                            <TextBox x:Name="txtEmployeeCode1" Style="{StaticResource MaterialDesignOutlinedTextFieldTextBox}"
                                                  VerticalAlignment="Top" Margin="0,10,10,0" Height="40" Width="440"
                                                  AcceptsReturn="True" TextWrapping="Wrap" HorizontalAlignment="Right"
                                                 VerticalScrollBarVisibility="Auto" materialDesign:HintAssist.Hint="Mã nhân viên"
                                                 IsEnabled="{Binding Path=IsChecked, ElementName=MaterialDesignOutlinedTextFieldTextBoxEnabledComboBox}" />

                            <TextBlock Width="200" Height="30" VerticalAlignment="Bottom" Margin="0,10,10,-50" 
                                                   Text="Tên đăng nhập (*)" HorizontalAlignment="Left" FontWeight="Bold"/>

                            <TextBox x:Name="txtUserName1" Style="{StaticResource MaterialDesignOutlinedTextFieldTextBox}"
                                                  VerticalAlignment="Top"  Margin="0,10,10,0" Height="40" Width="440"
                                                  AcceptsReturn="True" TextWrapping="Wrap" HorizontalAlignment="Right"
                                                 VerticalScrollBarVisibility="Auto" materialDesign:HintAssist.Hint="Tên đăng nhập"
                                                 IsEnabled="{Binding Path=IsChecked, ElementName=MaterialDesignOutlinedTextFieldTextBoxEnabledComboBox}" />

                            <TextBlock Width="200" Height="30" VerticalAlignment="Bottom" Margin="0,10,10,-50" 
                                                   Text="Mật khẩu (*)" HorizontalAlignment="Left" FontWeight="Bold"/>

                            <PasswordBox  x:Name="txtPass1" Margin="0,10,10,0" Height="40" Width="440" HorizontalAlignment="Right"
                                  Style="{StaticResource MaterialDesignOutlinedPasswordFieldPasswordBox}"
                                  VerticalAlignment="Top" IsEnabled="{Binding Path=IsChecked, ElementName=MaterialDesignOutlinedPasswordFieldPasswordBoxEnabledComboBox}"
                                   materialDesign:HintAssist.Hint="Mật khẩu" />

                            <TextBlock Width="200" Height="30" VerticalAlignment="Bottom" Margin="0,10,10,-50" 
                                                   Text="Nhập lại mật khẩu (*)" HorizontalAlignment="Left" FontWeight="Bold"/>

                            <PasswordBox  x:Name="txtCheckPass1" Margin="0,10,10,0" Height="40" Width="440" HorizontalAlignment="Right"
                                  Style="{StaticResource MaterialDesignOutlinedPasswordFieldPasswordBox}"
                                  VerticalAlignment="Top" IsEnabled="{Binding Path=IsChecked, ElementName=MaterialDesignOutlinedPasswordFieldPasswordBoxEnabledComboBox}"
                                   materialDesign:HintAssist.Hint="Nhập lại mật khẩu" />

                            <TextBlock Width="200" Height="30" VerticalAlignment="Bottom" Margin="0,10,10,-50" 
                                                   Text="Chức vụ (*)" HorizontalAlignment="Left" FontWeight="Bold"/>

                            <TextBox x:Name="txtPosition1" Style="{StaticResource MaterialDesignOutlinedTextFieldTextBox}"
                                                  VerticalAlignment="Top"  Margin="0,10,10,0" Height="40" Width="440"
                                                  AcceptsReturn="True" TextWrapping="Wrap" HorizontalAlignment="Right"
                                                 VerticalScrollBarVisibility="Auto" materialDesign:HintAssist.Hint="Chức vụ"
                                                 IsEnabled="{Binding Path=IsChecked, ElementName=MaterialDesignOutlinedTextFieldTextBoxEnabledComboBox}" />

                            <TextBlock Width="200" Height="30" VerticalAlignment="Bottom" Margin="0,10,10,-50" 
                                                   Text="Tài khoản Email (*)" HorizontalAlignment="Left" FontWeight="Bold"/>

                            <TextBox x:Name="txtEmail1" Style="{StaticResource MaterialDesignOutlinedTextFieldTextBox}"
                                                  VerticalAlignment="Top"  Margin="0,10,10,0" Height="40" Width="440"
                                                  AcceptsReturn="True" TextWrapping="Wrap" HorizontalAlignment="Right"
                                                 VerticalScrollBarVisibility="Auto" materialDesign:HintAssist.Hint="Tài khoản Email"
                                                 IsEnabled="{Binding Path=IsChecked, ElementName=MaterialDesignOutlinedTextFieldTextBoxEnabledComboBox}" />
                            <TextBlock Width="200" Height="30" VerticalAlignment="Bottom" Margin="0,10,10,-50" 
                                                   Text="Mật khẩu Email (*)" HorizontalAlignment="Left" FontWeight="Bold"/>


                            <PasswordBox  x:Name="txtEmailPass1" Margin="0,10,10,0" Height="40" Width="440" HorizontalAlignment="Right"
                                  Style="{StaticResource MaterialDesignOutlinedPasswordFieldPasswordBox}"
                                  VerticalAlignment="Top" IsEnabled="{Binding Path=IsChecked, ElementName=MaterialDesignOutlinedPasswordFieldPasswordBoxEnabledComboBox}"
                                   materialDesign:HintAssist.Hint="Mật khẩu Email" />


                            <TextBlock Width="200" Height="30" VerticalAlignment="Bottom" Margin="0,10,10,-50" 
                                                   Text="Số điện thoại (*)" HorizontalAlignment="Left" FontWeight="Bold"/>

                            <TextBox x:Name="txtPhoneNumber1" Style="{StaticResource MaterialDesignOutlinedTextFieldTextBox}"
                                                  VerticalAlignment="Top"  Margin="0,10,10,0" Height="40" Width="440"
                                                  AcceptsReturn="True" TextWrapping="Wrap" HorizontalAlignment="Right"
                                                 VerticalScrollBarVisibility="Auto" materialDesign:HintAssist.Hint="Số điện thoại"
                                                 IsEnabled="{Binding Path=IsChecked, ElementName=MaterialDesignOutlinedTextFieldTextBoxEnabledComboBox}" />


                            <TextBlock Width="200" Height="30" VerticalAlignment="Bottom" Margin="0,10,10,-50" 
                                                   Text="Đơn vị công tác" HorizontalAlignment="Left" FontWeight="Bold"/>

                            <TextBox x:Name="txtWorkAddress1" Style="{StaticResource MaterialDesignOutlinedTextFieldTextBox}"
                                                  VerticalAlignment="Top"  Margin="0,10,10,0" Height="40" Width="440"
                                                  AcceptsReturn="True" TextWrapping="Wrap" HorizontalAlignment="Right"
                                                 VerticalScrollBarVisibility="Auto" materialDesign:HintAssist.Hint="Đơn vị công tác"
                                                 IsEnabled="{Binding Path=IsChecked, ElementName=MaterialDesignOutlinedTextFieldTextBoxEnabledComboBox}" />

                            <TextBlock Width="200" Height="30" VerticalAlignment="Bottom" Margin="0,10,10,-50" 
                                                   Text="Quyền hạn" HorizontalAlignment="Left" FontWeight="Bold"/>

                            <ComboBox x:Name="cboRole" VerticalAlignment="Top"  Margin="0,10,10,0" Height="40" Width="440"
                                               HorizontalAlignment="Right" materialDesign:HintAssist.Hint="Quyền hạn"
                                               IsEnabled="{Binding Path=IsChecked, ElementName=MaterialDesignOutlinedTextFieldTextBoxEnabledComboBox}">

                                <ComboBoxItem Content="Quản lý"/>
                                <ComboBoxItem Content="Kỹ sư"/>
                                <ComboBoxItem Content="Người giám sát"/>
                                <ComboBoxItem Content="Nhân viên vận hành"/>
                            </ComboBox>


                            <Button Background="#01579B" BorderBrush="#01579B" Width="100" HorizontalAlignment="Right" VerticalAlignment="Bottom" Content="Lưu"
                                            x:Name="btnSaveSeting" Margin="0,70,10,0" Click="btnSaveSeting_Click"/>
                        </StackPanel>


                    </GroupBox>
                </materialDesign:Card>
            </Grid>
            <Grid Grid.Column="1">
                <materialDesign:Card Margin="16">
                    <GroupBox Background="AliceBlue" materialDesign:ColorZoneAssist.Mode="Standard"
                                      Header="Thiết lập thông tin gửi báo cáo"  Style="{DynamicResource MaterialDesignGroupBox}" 
                                      FontSize="12" materialDesign:ShadowAssist.ShadowDepth="Depth3" BorderThickness="0">
                        <StackPanel>

                            <TextBlock Width="120" Height="30" VerticalAlignment="Bottom" Margin="0,0,0,-50" 
                                                   Text="Tên người nhận (*)" HorizontalAlignment="Left" FontWeight="Bold"/>

                            <TextBox x:Name="txtName"  Style="{StaticResource MaterialDesignOutlinedTextFieldTextBox}"
                                                  VerticalAlignment="Top" Margin="0,10,10,0" Height="40" Width="440"
                                                  AcceptsReturn="True" TextWrapping="Wrap" HorizontalAlignment="Right"
                                                 VerticalScrollBarVisibility="Auto" materialDesign:HintAssist.Hint="Tên người nhận"
                                                 IsEnabled="{Binding IsChecked, ElementName=MaterialDesignOutlinedTextFieldTextBoxEnabledComboBox}" />

                            <TextBlock Width="200" Height="30" VerticalAlignment="Bottom" Margin="0,10,10,-50" 
                                                   Text="Mã nhân viên (*)" HorizontalAlignment="Left" FontWeight="Bold"/>

                            <TextBox x:Name="txtEmployeeCode"   Style="{StaticResource MaterialDesignOutlinedTextFieldTextBox}"
                                                  VerticalAlignment="Top" Margin="0,10,10,0" Height="40" Width="440"
                                                  AcceptsReturn="True" TextWrapping="Wrap" HorizontalAlignment="Right"
                                                 VerticalScrollBarVisibility="Auto" materialDesign:HintAssist.Hint="Mã nhân viên"
                                                 IsEnabled="{Binding IsChecked, ElementName=MaterialDesignOutlinedTextFieldTextBoxEnabledComboBox}" />

                            <TextBlock Width="200" Height="30" VerticalAlignment="Bottom" Margin="0,10,10,-50" 
                                                   Text="Chức vụ (*)" HorizontalAlignment="Left" FontWeight="Bold"/>

                            <TextBox x:Name="txtPosition"   Style="{StaticResource MaterialDesignOutlinedTextFieldTextBox}"
                                                  VerticalAlignment="Top"  Margin="0,10,10,0" Height="40" Width="440"
                                                  AcceptsReturn="True" TextWrapping="Wrap" HorizontalAlignment="Right"
                                                 VerticalScrollBarVisibility="Auto" materialDesign:HintAssist.Hint="Chức vụ"
                                                 IsEnabled="{Binding IsChecked, ElementName=MaterialDesignOutlinedTextFieldTextBoxEnabledComboBox}" />

                            <TextBlock Width="200" Height="30" VerticalAlignment="Bottom" Margin="0,10,10,-50" 
                                                   Text="Email nhận báo cáo (*)" HorizontalAlignment="Left" FontWeight="Bold"/>

                            <TextBox x:Name="txtEmail"   Style="{StaticResource MaterialDesignOutlinedTextFieldTextBox}"
                                                  VerticalAlignment="Top"  Margin="0,10,10,0" Height="40" Width="440"
                                                  AcceptsReturn="True" TextWrapping="Wrap" HorizontalAlignment="Right"
                                                 VerticalScrollBarVisibility="Auto" materialDesign:HintAssist.Hint="Email nhận báo cáo"
                                                 IsEnabled="{Binding IsChecked, ElementName=MaterialDesignOutlinedTextFieldTextBoxEnabledComboBox}" />


                            <TextBlock Width="200" Height="30" VerticalAlignment="Bottom" Margin="0,10,10,-50" 
                                                   Text="Số điện thoại (*)" HorizontalAlignment="Left" FontWeight="Bold"/>

                            <TextBox x:Name="txtPhoneNumber"   Style="{StaticResource MaterialDesignOutlinedTextFieldTextBox}"
                                                  VerticalAlignment="Top"  Margin="0,10,10,0" Height="40" Width="440"
                                                  AcceptsReturn="True" TextWrapping="Wrap" HorizontalAlignment="Right"
                                                 VerticalScrollBarVisibility="Auto" materialDesign:HintAssist.Hint="Số điện thoại"
                                                 IsEnabled="{Binding IsChecked, ElementName=MaterialDesignOutlinedTextFieldTextBoxEnabledComboBox}" />


                            <TextBlock Width="200" Height="30" VerticalAlignment="Bottom" Margin="0,10,10,-50" 
                                                   Text="Đơn vị công tác" HorizontalAlignment="Left" FontWeight="Bold"/>

                            <TextBox x:Name="txtWorkAddress"   Style="{StaticResource MaterialDesignOutlinedTextFieldTextBox}"
                                                  VerticalAlignment="Top"  Margin="0,10,10,0" Height="40" Width="440"
                                                  AcceptsReturn="True" TextWrapping="Wrap" HorizontalAlignment="Right"
                                                 VerticalScrollBarVisibility="Auto" materialDesign:HintAssist.Hint="Đơn vị công tác"
                                                 IsEnabled="{Binding IsChecked, ElementName=MaterialDesignOutlinedTextFieldTextBoxEnabledComboBox}" />

                            <Button Background="#01579B" BorderBrush="#01579B" Width="100" HorizontalAlignment="Right" VerticalAlignment="Bottom" Content="Lưu"
                                            x:Name="btnSave" Margin="0,320,10,0" Click="btnSave_Click"/>
                        </StackPanel>

                    </GroupBox>
                </materialDesign:Card>

            </Grid>
        </Grid>
    </Grid>
</Window>
