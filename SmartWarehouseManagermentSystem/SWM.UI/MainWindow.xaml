<Window x:Class="SWM.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SWM.UI"
        mc:Ignorable="d"
        xmlns:v="clr-namespace:SWM.UI.View"
        Title="Smart Warehouse Managerment System" Height="1080" Width="1930" 
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{StaticResource ContentBackgroundBrush}"
        FontFamily="{DynamicResource MaterialDesignFont}"  
        Closing="Window_Closing"  Loaded="Window_Loaded"
        MouseWheel="Window_MouseWheel" WindowState="Maximized">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="7.5*"/>
        </Grid.ColumnDefinitions>

        <!--Tab điều khiển-->
        <Grid Grid.Column="0">

            <Grid.RowDefinitions>
                <RowDefinition Height="3.5*"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="14*"/>
                <RowDefinition Height="1.5*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="{StaticResource SidebarBackgroundBrush}">
                <Image Source=".\Resources\TA logo2.png"/>
                <Rectangle StrokeThickness="1" Width="1" HorizontalAlignment="Right" Fill="{StaticResource SidebarBorderBrush}"/>
            </Grid>
            <Grid Grid.Row="1" Background="{StaticResource SidebarBackgroundBrush}">
                <Button Height="69" Background="Transparent" BorderBrush="Transparent"
                        x:Name="btnDashboard" Click="btnDashboard_Click" />
                <md:PackIcon Kind="ViewDashboardOutline" Width="35" Height="35" VerticalAlignment="Center" Foreground="{StaticResource SidebarForegroundBrush}"
                             MouseDown="btnDashboard_Click" Margin="30,0,0,0"/>
                <TextBlock Text="Dashboard" FontSize="16" Height="20" Margin="90,0,0,0" Foreground="{StaticResource SidebarForegroundBrush}"
                           MouseDown="btnDashboard_Click"/>
                <Rectangle StrokeThickness="1" Width="1" HorizontalAlignment="Right" Fill="{StaticResource SidebarBorderBrush}"/>
            </Grid>
            <Grid Grid.Row="2" Background="{StaticResource SidebarBackgroundBrush}">
                <Button Height="69" Background="Transparent" BorderBrush="Transparent"
                        x:Name="btnDetail" Click="btnBufferDetail_Click"/>
                <md:PackIcon Kind="Finance" Width="35" Height="35" VerticalAlignment="Center" Foreground="{StaticResource SidebarForegroundBrush}"
                             Margin="30,0,0,0" x:Name="picDetail" MouseDown="btnBufferDetail_Click"/>
                <TextBlock Text=" STK Detail" FontSize="16" Height="20" Foreground="{StaticResource SidebarForegroundBrush}"
                           MouseDown="btnBufferDetail_Click" Margin="90,0,0,0"/>
                <Rectangle StrokeThickness="1" Width="1" HorizontalAlignment="Right" Fill="{StaticResource SidebarBorderBrush}"/>
            </Grid>
            <Grid Grid.Row="3" Background="{StaticResource SidebarBackgroundBrush}">
                <Button Height="69" Background="Transparent" BorderBrush="Transparent"
                        x:Name="btnHistory" Click="btnCommandHistory_Click"/>
                <md:PackIcon Kind="ArrangeSendBackward" Width="35" Height="35" VerticalAlignment="Center" Foreground="{StaticResource SidebarForegroundBrush}"
                             Margin="30,0,0,0" MouseDown="btnCommandHistory_Click"/>
                <TextBlock Text="Job History" FontSize="16" Height="20" Margin="90,0,0,0" Foreground="{StaticResource SidebarForegroundBrush}"
                           MouseDown="btnCommandHistory_Click"/>
                <Rectangle StrokeThickness="1" Width="1" HorizontalAlignment="Right" Fill="{StaticResource SidebarBorderBrush}"/>
            </Grid>
            <Grid Grid.Row="4" Background="{StaticResource SidebarBackgroundBrush}">
                <Button Height="69" Background="Transparent" BorderBrush="Transparent"
                        x:Name="btnControl" Click="btnManualControl_Click"/>
                <md:PackIcon Kind="Apps" Width="35" Height="35" VerticalAlignment="Center" Foreground="{StaticResource SidebarForegroundBrush}"
                             Margin="30,0,0,0" MouseDown="btnManualControl_Click"/>
                <TextBlock Text="Manual Control" FontSize="16" Height="20" Foreground="{StaticResource SidebarForegroundBrush}"
                           Margin="90,0,0,0" MouseDown="btnManualControl_Click"/>
                <Rectangle StrokeThickness="1" Width="1" HorizontalAlignment="Right" Fill="{StaticResource SidebarBorderBrush}"/>
            </Grid>
            <Grid Grid.Row="5" Background="{StaticResource SidebarBackgroundBrush}">
                <Button Height="69" x:Name="btnExit" Click="btnExit_Click" VerticalAlignment="Top"
                        Background="Transparent" BorderBrush="Transparent" />
                <md:PackIcon Kind="ExitToApp" Width="35" Height="35" VerticalAlignment="Center" Foreground="{StaticResource SidebarForegroundBrush}"
                             Margin="30,0,0,0" MouseDown="btnExit_Click"/>
                <TextBlock Text="Exit" FontSize="16" Height="20" Margin="90,0,0,0"
                           Foreground="{StaticResource SidebarForegroundBrush}" MouseDown="btnExit_Click"/>
                <Rectangle StrokeThickness="1" Width="1" HorizontalAlignment="Right" Fill="{StaticResource SidebarBorderBrush}"/>
            </Grid>
            <Grid Grid.Row="6" Background="{StaticResource SidebarBackgroundBrush}">
                <Rectangle StrokeThickness="1" Width="1" HorizontalAlignment="Right" Fill="{StaticResource SidebarBorderBrush}"/>
            </Grid>
            <Grid Grid.Row="7" Background="{StaticResource SidebarBackgroundBrush}">
                <Rectangle StrokeThickness="1" Width="1" HorizontalAlignment="Right" Fill="{StaticResource SidebarBorderBrush}"/>
            </Grid>
            <Grid Grid.Row="8" Background="{StaticResource SidebarBackgroundBrush}">
                <Rectangle StrokeThickness="1" Width="1" HorizontalAlignment="Right" Fill="{StaticResource SidebarBorderBrush}"/>
            </Grid>
            <Grid Grid.Row="9" Background="{StaticResource SidebarBackgroundBrush}">
                <Rectangle StrokeThickness="1" Width="1" HorizontalAlignment="Right" Fill="{StaticResource SidebarBorderBrush}"/>
            </Grid>
            <Grid Grid.Row="10" Background="{StaticResource SidebarBackgroundBrush}">
                <Image Source=".\Resources\Logo user.png" Width="60" HorizontalAlignment="Left"/>
                <TextBlock x:Name="lblUser" Text="Trần Tuấn Em" Foreground="{StaticResource SidebarForegroundBrush}" FontSize="12" Height="15" Margin="60,0,0,0"/>
                <Ellipse Height="8" Width="8" HorizontalAlignment="Left" Margin="60,23,0,0" Fill="#27AE60"/>
                <TextBlock Text="Online" FontSize="8" Height="10" Foreground="{StaticResource SidebarMutedBrush}" Margin="70,25,0,0"/>
                <Rectangle StrokeThickness="1" Width="1" HorizontalAlignment="Right" Fill="{StaticResource SidebarBorderBrush}"/>
            </Grid>

        </Grid>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="7*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}">

            </Grid>
            <Grid Grid.Row="1" Background="{StaticResource SurfaceBrush}">
                <Border BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="5*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="0*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="0.6*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="1">
                            <v:ArcGauge x:Name="AGV_Connect"
                                    AngleValue="0"
                                    TotalValue= "1"
                                    FullValue="1"                                    
                                    EmptyValue="0"
                                    ColorArc1Value="{StaticResource GaugeArcPrimaryBrush}"
                                    ColorArc2Value="{StaticResource GaugeArcSecondaryBrush}"
                                    ColorText1Value="{StaticResource GaugeLegendBrush}"
                                    ColorText2Value="{StaticResource GaugeArcSecondaryBrush}"
                                    Text1Value="C" 
                                    Text2Value="D" 
                                    VerticalAlignment="Bottom" 
                                    Height="127" Margin="0,-3,0,-15"/>
                        </Grid>
                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="5*"/>
                                <RowDefinition Height="2*"/>
                            </Grid.RowDefinitions>
                            <!--<Rectangle  Height="80" Width="1" Fill="Gray" HorizontalAlignment="Left" Margin="0,20"/>-->
                            <Grid Grid.Row="0" Grid.Column="0">
                                <Label x:Name="lbl_LoadCount" Content="000" HorizontalAlignment="Center" VerticalContentAlignment="Center" FontSize="40" FontWeight="Bold"/>
                            </Grid>

                            <Grid Grid.Row="0" Grid.Column="1">
                                <Rectangle Width="1" Fill="{StaticResource BorderLightBrush}" HorizontalAlignment="Right"/>
                                <Label x:Name="lbl_UnloadCount" Content="000" HorizontalAlignment="Center" VerticalContentAlignment="Center" FontSize="40" FontWeight="Bold"/>
                            </Grid>

                            <Grid Grid.Row="2" Grid.Column="0">
                                <Label Content="LOAD" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                            </Grid>

                            <Grid Grid.Row="2" Grid.Column="1">
                                <Rectangle Width="1" Fill="{StaticResource BorderLightBrush}" HorizontalAlignment="Right"/>
                                <Label Content="UNLOAD" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                            </Grid>

                        </Grid>
                        <Grid Grid.Column="2">
                            <v:ArcGauge x:Name="AGV_FullState"
                                    AngleValue="{Binding Angle_Empty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TotalValue="{Binding TotalAGV, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    FullValue="{Binding Full_Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    EmptyValue="{Binding Empty_Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    ColorArc1Value="{StaticResource GaugeArcPrimaryBrush}"
                                    ColorArc2Value="{StaticResource GaugeArcSecondaryBrush}"
                                    ColorText1Value="{StaticResource GaugeLegendBrush}"
                                    ColorText2Value="{StaticResource GaugeArcSecondaryBrush}"
                                    Text1Value="F" 
                                    Text2Value="E" 
                                    VerticalAlignment="Bottom" 
                                    Height="127"
                                    TitleValue="CONNECT" Margin="0,-3,0,-15"/>

                        </Grid>
                        <Grid Grid.Column="3">
                            <v:ArcGauge x:Name="AGV_RunState"
                                    AngleValue="{Binding AngleDisconnect, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TotalValue="{Binding TotalAGV, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    FullValue="{Binding Run_value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    EmptyValue="{Binding Stop_Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    ColorArc1Value="{StaticResource GaugeArcPrimaryBrush}"
                                    ColorArc2Value="{StaticResource GaugeArcSecondaryBrush}"
                                    ColorText1Value="{StaticResource GaugeLegendBrush}"
                                    ColorText2Value="{StaticResource GaugeArcSecondaryBrush}"
                                    Text1Value="R" 
                                    Text2Value="S" 
                                    VerticalAlignment="Bottom" 
                                    Height="127"
                                    TitleValue="CONNECT" Margin="0,-3,0,-15"/>

                        </Grid>
                        <Grid Grid.Column="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="0.1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1*"/>
                                <RowDefinition Height="0.1*"/>
                                <RowDefinition Height="1*"/>
                                <!--<RowDefinition Height="0.1*"/>-->
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Grid.Column="0" Background="{StaticResource StatBoxBackgroundBrush}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="3*"/>
                                    <RowDefinition Height="1.5*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Label Content="000" HorizontalAlignment="Center" VerticalContentAlignment="Center" FontSize="17" FontWeight="Bold"/>
                                </Grid>
                                <Grid Grid.Row="1">
                                    <Label Content="5 MIN" 
                                               HorizontalAlignment="Center" VerticalContentAlignment="Center" 
                                               FontSize="9" Width="32" />
                                </Grid>

                            </Grid>

                            <Grid Grid.Row="0" Grid.Column="2" Background="{StaticResource StatBoxBackgroundBrush}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="3*"/>
                                    <RowDefinition Height="1.5*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Label Content="000" HorizontalAlignment="Center" VerticalContentAlignment="Center" FontSize="17" FontWeight="Bold"/>
                                </Grid>
                                <Grid Grid.Row="1">
                                    <Label Content="10 MIN" 
                                               HorizontalAlignment="Center" VerticalContentAlignment="Center" 
                                               FontSize="9" Width="38"/>
                                </Grid>

                            </Grid>
                            <Grid Grid.Row="2" Grid.Column="0" Background="{StaticResource StatBoxBackgroundBrush}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="3*"/>
                                    <RowDefinition Height="1.5*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Label Content="000" HorizontalAlignment="Center" VerticalContentAlignment="Center" FontSize="17" FontWeight="Bold"/>
                                </Grid>
                                <Grid Grid.Row="1">
                                    <Label Content="15 MIN" 
                                               HorizontalAlignment="Center" VerticalContentAlignment="Center" 
                                               FontSize="9" Width="38"/>
                                </Grid>

                            </Grid>
                            <Grid Grid.Row="2" Grid.Column="2" Background="{StaticResource StatBoxBackgroundBrush}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="3*"/>
                                    <RowDefinition Height="1.5*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Label Content="000" HorizontalAlignment="Center" VerticalContentAlignment="Center" FontSize="17" FontWeight="Bold"/>
                                </Grid>
                                <Grid Grid.Row="1">
                                    <Label Content="20 MIN" 
                                               HorizontalAlignment="Center" VerticalContentAlignment="Center" 
                                               FontSize="9" Width="38"/>
                                </Grid>

                            </Grid>

                        </Grid>
                        <Grid Grid.Column="5">
                            <Rectangle Width="1" Fill="{StaticResource BorderLightBrush}" HorizontalAlignment="Left"/>
                            <v:ArcGauge x:Name="Buffer_FullState"
                                    AngleValue="{Binding AngleDisconnect, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TotalValue="{Binding TotalAGV, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    FullValue="{Binding Full_value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    EmptyValue="{Binding Empty_Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    ColorArc1Value="{StaticResource GaugeArcPrimaryBrush}"
                                    ColorArc2Value="{StaticResource GaugeArcSecondaryBrush}"
                                    ColorText1Value="{StaticResource GaugeLegendBrush}"
                                    ColorText2Value="{StaticResource GaugeArcSecondaryBrush}"
                                    Text1Value="F" 
                                    Text2Value="E" 
                                    VerticalAlignment="Bottom" 
                                    Height="127"
                                    TitleValue="CONNECT" HorizontalAlignment="Left" Margin="0,-3,0,-15" Width="219" />

                        </Grid>
                        <!--<Grid Grid.Column="6">
                                <v:ArcGauge Width="222" 
                                    AngleValue="{Binding AngleDisconnect, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TotalValue="{Binding TotalAGV, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    FullValue="{Binding Full_value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    EmptyValue="{Binding Empty_Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    ColorArc1Value="{StaticResource GaugeArcPrimaryBrush}"
                                    ColorArc2Value="{StaticResource GaugeArcSecondaryBrush}"
                                    ColorText1Value="{StaticResource GaugeLegendBrush}"
                                    ColorText2Value="{StaticResource GaugeArcSecondaryBrush}"
                                    Text1Value="F" 
                                    Text2Value="E" 
                                    VerticalAlignment="Bottom" 
                                    Height="127"
                                    TitleValue="CONNECT" Margin="1,0,-53,-20" />

                            </Grid>-->
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="5*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <!--<Grid Grid.Column="0">
                            <Label Content="System" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                        </Grid>-->
                        <Grid Grid.Column="1">
                            <Label Content="COMMAND" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                        <Grid Grid.Column="2">
                            <Label Content="VEHICLE" 
                                       HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                        <Grid Grid.Column="3">
                            <Label Content="BUFFER" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                        <!--<Grid Grid.Column="4">
                                <Label Content="FULL STATE" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                            </Grid>-->
                        <!--<Grid Grid.Column="5">
                                <Label Content="FULL STATE" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                            </Grid>
                            <Grid Grid.Column="7">
                                <Label Content="FULL STATE" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                            </Grid>-->
                    </Grid>
                </Grid>
            </Grid>
            <Grid Grid.Row="2">
                <Grid x:Name="Grid_Map" Background="{StaticResource ContentBackgroundBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sơ đồ kho -->
                    <Grid Grid.Column="0">
                        <StackPanel Name="map">
                            <Canvas x:Name="cvs_Map" Margin="60,15,0,0" Height="853"
                                 RenderTransformOrigin="0.5,0.5">
                                <Canvas.RenderTransform>
                                    <MatrixTransform x:Name="mt"/>
                                </Canvas.RenderTransform>
                            </Canvas>
                        </StackPanel>
                    </Grid>

                    <!-- Panel trạng thái kết nối -->
                    <Border Grid.Column="1" Margin="8,12,12,12"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1" CornerRadius="6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="14,12">
                                <TextBlock Text="SYSTEM MONITOR" FontSize="13" FontWeight="Bold"
                                           Foreground="{StaticResource PanelHeaderBrush}" Margin="0,0,0,4"/>
                                <TextBlock x:Name="lblConnUpdated" FontSize="10"
                                           Foreground="{StaticResource PanelMutedTextBrush}" Margin="0,0,0,12"/>

                                <!-- PLC -->
                                <Border Background="{StaticResource StatBoxBackgroundBrush}" CornerRadius="4"
                                        Padding="10,8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="PLC Mitsubishi" FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{StaticResource GaugeLabelBrush}" Margin="0,0,0,6"/>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="MX Component" FontSize="11" Foreground="{StaticResource PanelMutedTextBrush}"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Ellipse x:Name="indPlcConn" Width="8" Height="8" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="lblPlcConn" FontSize="11" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Network Ping" FontSize="11" Foreground="{StaticResource PanelMutedTextBrush}"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Ellipse x:Name="indPlcPing" Width="8" Height="8" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="lblPlcPing" FontSize="11" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock x:Name="lblPlcAddress" FontSize="10" Foreground="{StaticResource PanelMutedTextBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Serial -->
                                <Border Background="{StaticResource StatBoxBackgroundBrush}" CornerRadius="4"
                                        Padding="10,8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="Serial Port" FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{StaticResource GaugeLabelBrush}" Margin="0,0,0,6"/>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Cổng COM" FontSize="11" Foreground="{StaticResource PanelMutedTextBrush}"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Ellipse x:Name="indSerial" Width="8" Height="8" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="lblSerialStatus" FontSize="11" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock x:Name="lblSerialConfig" FontSize="10" Foreground="{StaticResource PanelMutedTextBrush}" Margin="0,4,0,0"/>
                                        <TextBlock Text="Trigger: C1x → nhập IP01" FontSize="10"
                                                   Foreground="{StaticResource PanelMutedTextBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Database -->
                                <Border Background="{StaticResource StatBoxBackgroundBrush}" CornerRadius="4"
                                        Padding="10,8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="Database" FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{StaticResource GaugeLabelBrush}" Margin="0,0,0,6"/>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="SQL Server" FontSize="11" Foreground="{StaticResource PanelMutedTextBrush}"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Ellipse x:Name="indDatabase" Width="8" Height="8" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="lblDatabaseStatus" FontSize="11" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="SmartWarehouse" FontSize="10"
                                                   Foreground="{StaticResource PanelMutedTextBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Thiết bị -->
                                <Border Background="{StaticResource StatBoxBackgroundBrush}" CornerRadius="4"
                                        Padding="10,8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="Thiết bị" FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{StaticResource GaugeLabelBrush}" Margin="0,0,0,6"/>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="AGV" FontSize="11" Foreground="{StaticResource PanelMutedTextBrush}"/>
                                            <TextBlock x:Name="lblAgvInfo" Grid.Column="1" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        </Grid>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="IP01" FontSize="11" Foreground="{StaticResource PanelMutedTextBrush}"/>
                                            <TextBlock x:Name="lblIp01State" Grid.Column="1" FontSize="11" FontWeight="SemiBold"/>
                                        </Grid>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="OP01" FontSize="11" Foreground="{StaticResource PanelMutedTextBrush}"/>
                                            <TextBlock x:Name="lblOp01State" Grid.Column="1" FontSize="11" FontWeight="SemiBold"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Lệnh hiện tại -->
                                <Border Background="{StaticResource StatBoxBackgroundBrush}" CornerRadius="4"
                                        Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="Lệnh hiện tại" FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{StaticResource GaugeLabelBrush}" Margin="0,0,0,6"/>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Trạng thái" FontSize="11" Foreground="{StaticResource PanelMutedTextBrush}"/>
                                            <TextBlock x:Name="lblJobStatus" Grid.Column="1" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        </Grid>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Tuyến" FontSize="11" Foreground="{StaticResource PanelMutedTextBrush}"/>
                                            <TextBlock x:Name="lblJobRoute" Grid.Column="1" FontSize="10" TextWrapping="Wrap"
                                                       Foreground="{StaticResource GaugeLabelBrush}"/>
                                        </Grid>
                                        <TextBlock x:Name="lblJobId" FontSize="9" Foreground="{StaticResource PanelMutedTextBrush}"
                                                   Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Grid x:Name="Grid_AGVDetail">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.5*"/>
                        <RowDefinition Height="18*"/>
                        <RowDefinition Height="0.5*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}">
                        <Image Source=".\Resources\Moitruong.jpg" HorizontalAlignment="Left" 
                               Height="35" Width="35" Margin="20,0,0,0"/>
                        <TextBlock Text="Chi tiết trạng thái Kho chứa" FontSize="20" FontWeight="DemiBold"
                              VerticalAlignment="Center" Margin="60,0,0,0" Height="25"/>
                    </Grid>
                    <Grid Grid.Row="1">
                        <DataGrid x:Name="dtgBFData" IsReadOnly="True"/>
                    </Grid>
                </Grid>

                <Grid x:Name="Grid_CommandHistory" Background="{StaticResource ContentBackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.5*"/>
                        <RowDefinition Height="18*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Background="{StaticResource SurfaceBrush}">
                            <Image Source=".\Resources\Moitruong.jpg" HorizontalAlignment="Left" 
                               Height="35" Width="35" Margin="20,0,0,0"/>
                            <TextBlock Text="Chi tiết lịch sử thực hiện lệnh vận chuyển" FontSize="20" FontWeight="DemiBold"
                              VerticalAlignment="Center" Margin="60,0,0,0" Height="25"/>
                        </Grid>

                    </Grid>
                    <Grid Grid.Row="1">
                        <DataGrid x:Name="dtgCommandHistory" IsReadOnly="True" 
                                  SelectedCellsChanged="dtgCommandHistory_SelectedCellsChanged">
                            <!--<DataGridTextColumn Header="Nombre"
                          Binding="{Binding Nombre}">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                            </DataGridTextColumn>-->
                        </DataGrid>

                    </Grid>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="1">

                            <Button x:Name="btnAddCommand" Content="Tạo lệnh" Click="btnAddCommand_Click"
                                    BorderBrush="{StaticResource ButtonPrimaryBorderBrush}"
                                    Background="{StaticResource ButtonPrimaryBrush}" Width="120" Height="35"
                                    FontSize="14" Foreground="{StaticResource SidebarForegroundBrush}" Grid.Column="1"/>
                        </Grid>
                        <Grid Grid.Column="2">

                            <Button x:Name="btnDeleteCommand" Content="Xóa lệnh" Click="btnDeleteCommand_Click"
                                    BorderBrush="{StaticResource ButtonPrimaryBorderBrush}"
                                    Background="{StaticResource ButtonPrimaryBrush}" Width="120" Height="35"
                                    FontSize="14" Foreground="{StaticResource SidebarForegroundBrush}" Grid.Column="1"/>
                        </Grid>
                    </Grid>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>
