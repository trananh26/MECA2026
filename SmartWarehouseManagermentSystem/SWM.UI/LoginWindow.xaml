<Window x:Class="SWM.UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SWM.UI"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Title="LoginWindow" Height="450" Width="650" WindowStyle="None" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" 
        Loaded="Window_Loaded">
    <Grid>


        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0"  Background="#E1F5FC">
            <Image Source=".\Resources\IOT2.png" Height="320" Margin="0,65,0,0"/>
            <Image Source=".\Resources\Mylogo3.png" Height="66" Width="325" 
                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-10,0,0,0"/>

        </Grid>

        <Grid Grid.Column="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="100*"/>
                    <RowDefinition Height="250*"/>
                    <RowDefinition Height="50*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">

                    <TextBox Text="LOGIN" FontSize="30" FontWeight="Bold"                                      
                     HorizontalContentAlignment="Left"  VerticalContentAlignment="Bottom" 
                     Foreground="#6D4C41" Margin="116,0,115,12" Height="45" VerticalAlignment="Bottom"
                     />
                </Grid>
                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="43*"/>
                        <RowDefinition Height="35*"/>
                        <RowDefinition Height="35*"/>
                        <RowDefinition Height="50*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="1" Grid.Row="0"
                      x:Name="cbb_floor" materialDesign:HintAssist.Hint="--Chọn Server--" 
                      Height="30" Width="120" HorizontalContentAlignment="Center" SelectionChanged="cbb_floor_SelectionChanged" >
                        <ComboBoxItem Content="V1-1F"/>
                    </ComboBox>

                    <TextBox Grid.Column="1" Grid.Row="1" x:Name="txbUser" 
                     materialDesign:HintAssist.Hint="Tài khoản" 
                     Height="30" Width="120"                    
                     HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                     />
                    <PasswordBox Grid.Column="1" Grid.Row="2" x:Name="txbPassWord"
                    materialDesign:HintAssist.Hint="Mật khẩu"
                    materialDesign:TextFieldAssist.SuffixText ="True"
                    Height="30" Width="120"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
                    KeyDown="txbPassWord_KeyDown"/>
                    <materialDesign:PackIcon Grid.Column="0" Grid.Row="0" HorizontalAlignment="Right" 
                                     VerticalAlignment="Center"
                                     Kind="DatabaseImport" 
                                     Width="30" Height="30"
                                     />
                    <materialDesign:PackIcon Grid.Column="0" Grid.Row="1" HorizontalAlignment="Right" 
                                     VerticalAlignment="Center"
                                     Kind="Account" 
                                     Width="30" Height="30"/>
                    <materialDesign:PackIcon Grid.Column="0" Grid.Row="2" HorizontalAlignment="Right" 
                                     VerticalAlignment="Center"
                                     Kind="Key" 
                                     Width="30" Height="30"/>

                    <Button Name="btnLogin" Width="70"
                    Style="{StaticResource MaterialDesignRaisedButton}" 
                    Background="#7986CB"
                    Content="Login" HorizontalAlignment="Left" Click="btnLogin_Click"
                    VerticalAlignment="Bottom" Grid.Column="2" Grid.Row="3"
                    />
                    <Button Name="btnExit" Width="70"
                    Style="{StaticResource MaterialDesignRaisedButton}" 
                    Background="#7986CB"
                    ToolTip="Resource name: MaterialDesignRaisedButton"
                    Content="Exit"  Click="btnExit_Click"
                    VerticalAlignment="Bottom" Grid.Column="1" Grid.Row="3" Margin="95,0,10,0"
                    />
                    <Label Name="lbl_ChangePassword" Content="Đổi mật khẩu" MouseDown="lbl_ChangePassword_MouseDown" Margin="70,10,162,43" 
                   Grid.Row="3" Foreground="Indigo" FontWeight="DemiBold" Cursor="Hand" Grid.ColumnSpan="2"/>
                    <Label Name="lbl_ForgetPassword" Content="Quên Mật khẩu?" MouseDown="lbl_ForgetPassword_MouseDown" Grid.Column="1" Margin="0,10,38,43" 
                   Grid.Row="3" Foreground="Indigo" FontWeight="DemiBold" Cursor="Hand" HorizontalAlignment="Right" Width="107"
                   IsEnabled="False"/>

                </Grid>
                <Grid Grid.Row="2">
                    <Label Content="ĐẠI HỌC CÔNG NGHIỆP HÀ NỘI" FontSize="15" Foreground="#304FFE" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,14"/>
                    <Grid Height="15" VerticalAlignment="Bottom">
                        <StackPanel Margin="2,1,2,1">
                            <TextBlock  
                               Text="Copyright © 2022 by Faculty Of Electronics" FontSize="11" HorizontalAlignment="Right"  />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
